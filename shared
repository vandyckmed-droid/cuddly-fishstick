def _fmt_z(x):
    if x is None or not np.isfinite(x):
        return "—"
    return f"{x:+.2f}"


def _fmt_pct(x, dp=1):
    if x is None or not np.isfinite(x):
        return "—"
    return f"{x * 100:.{dp}f}%"


def run_self_tests():
    print("=" * 72)
    print("  shared.py self-tests")
    print("=" * 72)

    if not db.cache_exists():
        print("  FAIL: cache.db does not exist. Run cache.py first.")
        return False

    conn = db.open_cache(read_only=True)
    failures = 0

    # Load everything from cache
    universe = db.load_universe(conn, include_market=False)
    fin_records = db.load_all_financials(conn)
    fins = {t: db.extract_fields(fin_records.get(t)) for t in universe
            if fin_records.get(t)}
    price_with_dates = db.load_prices_bulk_with_dates(
        conn, universe + [db.MARKET_TICKER]
    )
    mkt_dates, mkt_close = db.load_market(conn)
    sectors_map = db.load_universe_with_sectors(conn)

    print(f"  Loaded: {len(universe)} tickers, "
          f"{len(fins)} financials, "
          f"{len(price_with_dates)} price series\n")

    # Compute factors
    tix, data = compute_factors(fins, price_with_dates, mkt_dates, mkt_close)
    print(f"  Factor model produced {len(tix)} tickers\n")

    # Print full table
    print("  FACTOR TABLE")
    print("  " + "-" * 68)
    print(f"  {'Ticker':<7}{'Sector':<22}"
          f"{'Value':>9}{'Quality':>10}{'Mom':>8}{'Comp':>8}{'Rank':>6}")
    print("  " + "-" * 68)
    rank_order = sorted(
        range(len(tix)),
        key=lambda i: (
            -data["composite"][i] if np.isfinite(data["composite"][i])
            else float("inf")
        ),
    )
    for i in rank_order:
        t = tix[i]
        sec = (data["sectors"][i] or "")[:20]
        print(
            f"  {t:<7}{sec:<22}"
            f"{_fmt_z(data['value'][i]):>9}"
            f"{_fmt_z(data['quality'][i]):>10}"
            f"{_fmt_z(data['momentum'][i]):>8}"
            f"{_fmt_z(data['composite'][i]):>8}"
            f"{int(data['rank'][i]) if np.isfinite(data['rank'][i]) else '—':>6}"
        )
    print("  " + "-" * 68)

    # Residual momentum diagnostics for all tickers
    print("\n  RESIDUAL MOMENTUM — all tickers")
    print("  " + "-" * 68)
    print(f"  {'Ticker':<7}{'β':>8}{'res sum':>10}{'res std':>10}"
          f"{'m_long':>10}{'m_short':>10}")
    print("  " + "-" * 68)
    for t in sorted(price_with_dates.keys()):
        if t == db.MARKET_TICKER:
            continue
        s_dates, s_close = price_with_dates[t]
        ml, ms, dbg = compute_residual_tstat_momentum_one(
            s_dates, s_close, mkt_dates, mkt_close
        )
        beta = dbg.get("beta")
        rsum = dbg.get("residual_sum")
        rstd = dbg.get("residual_std")
        beta_s = f"{beta:+.2f}" if beta is not None and np.isfinite(beta) else "—"
        rsum_s = f"{rsum:+.3f}" if rsum is not None and np.isfinite(rsum) else "—"
        rstd_s = f"{rstd:.4f}" if rstd is not None and np.isfinite(rstd) else "—"
        ml_s = f"{ml:+.2f}" if np.isfinite(ml) else "—"
        ms_s = f"{ms:+.2f}" if np.isfinite(ms) else "—"
        print(f"  {t:<7}{beta_s:>8}{rsum_s:>10}{rstd_s:>10}"
              f"{ml_s:>10}{ms_s:>10}")
    print("  " + "-" * 68)

    # ----- TESTS -----
    print("\n  TESTS")
    print("  " + "-" * 68)

    # T1: All 8 tickers produce a finite composite
    finite_n = int(np.isfinite(data["composite"]).sum())
    if finite_n == 8:
        print(f"  ✓ all 8 tickers have finite composite ({finite_n}/8)")
    else:
        failures += 1
        print(f"  ✗ composite finite count: {finite_n}/8 (expected 8)")

    # T2: LULU residual momentum is negative
    lulu_idx = tix.index("LULU") if "LULU" in tix else None
    if lulu_idx is not None:
        lulu_m_long = data["subs"]["m_long_raw"][lulu_idx]
        lulu_m_short = data["subs"]["m_short_raw"][lulu_idx]
        if lulu_m_long < 0 and lulu_m_short < 0:
            print(f"  ✓ LULU residual momentum is negative "
                  f"(m_long={lulu_m_long:+.2f}, m_short={lulu_m_short:+.2f})")
        else:
            failures += 1
            print(f"  ✗ LULU residual momentum should be negative "
                  f"(m_long={lulu_m_long:+.2f}, m_short={lulu_m_short:+.2f})")
    else:
        failures += 1
        print(f"  ✗ LULU not found in factor output")

    # T3: Sector counts match expectation
    expected_sectors = {
        "Technology": 3,
        "Financial Services": 2,
        "Consumer Cyclical": 1,
        "Consumer Defensive": 1,
        "Energy": 1,
    }
    actual = data["sector_sizes"]
    sector_ok = all(actual.get(k, 0) == v for k, v in expected_sectors.items())
    if sector_ok and len(actual) == len(expected_sectors):
        print(f"  ✓ sector groups correct: {actual}")
    else:
        failures += 1
        print(f"  ✗ sector groups: got {actual}, expected {expected_sectors}")

    # T4: Build book — should produce a valid portfolio
    book = build_book(price_with_dates, tix, data, sectors_map, n=TOP_N)
    if book is None:
        failures += 1
        print(f"  ✗ build_book returned None")
    else:
        w_rel = book["w_rel"]
        sigma_p = book["sigma_p"]
        scale = book["scale"]

        # Weights sum to ~1 (relative book)
        w_rel_sum = float(w_rel.sum())
        if abs(w_rel_sum - 1.0) < 1e-6:
            print(f"  ✓ w_rel sums to 1.0 ({w_rel_sum:.6f})")
        else:
            failures += 1
            print(f"  ✗ w_rel sum: {w_rel_sum} (expected 1.0)")

        # No sector exceeds cap (allow 0.5% slack — proportional rebalancer
        # converges asymptotically when 2 large sectors trade weight)
        sec_sums = {}
        for j, t in enumerate(book["kept"]):
            s = sectors_map.get(t, "Unknown")
            sec_sums[s] = sec_sums.get(s, 0.0) + float(w_rel[j])
        max_sec = max(sec_sums.values()) if sec_sums else 0.0
        cap_tolerance = 0.005
        if max_sec <= SECTOR_CAP + cap_tolerance:
            print(f"  ✓ sector cap holds (max sector = {max_sec*100:.2f}%, "
                  f"cap = {SECTOR_CAP*100:.0f}% + {cap_tolerance*100:.1f}% tol)")
        else:
            failures += 1
            print(f"  ✗ sector cap violated: max = {max_sec*100:.2f}% "
                  f"(cap = {SECTOR_CAP*100:.0f}%, tol = {cap_tolerance*100:.1f}%)")

        # Vol scale finite
        if np.isfinite(sigma_p) and np.isfinite(scale):
            print(f"  ✓ portfolio vol = {sigma_p*100:.1f}% (annual), "
                  f"scale = {scale:.2f}×")
        else:
            failures += 1
            print(f"  ✗ vol/scale not finite (sigma_p={sigma_p}, "
                  f"scale={scale})")

        # cap_info
        ci = book["cap_info"]
        if ci["capped_sectors"]:
            print(f"  ℹ sector cap engaged on: {ci['capped_sectors']} "
                  f"({ci['iters']} iter)")
        else:
            print(f"  ℹ no sectors hit cap")

    conn.close()

    print("=" * 72)
    if failures == 0:
        print(f"  ALL TESTS PASSED")
    else:
        print(f"  {failures} TEST(S) FAILED")
    print("=" * 72)
    return failures == 0


if __name__ == "__main__":
    run_self_tests()
